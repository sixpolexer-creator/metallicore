{
  "name": "metallicore-platform",
  "version": "0.1.0",
  "private": true,
  "description": "MetalliCore Engineering Knowledge Platform — monorepo root.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/plugins/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @metallicore/web",
    "build": "npm run build --workspace @metallicore/web",
    "start": "npm run start --workspace @metallicore/web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down"
  },
  "engines": {
    "node": ">=20"
  }
}
