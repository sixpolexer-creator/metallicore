NODE_ENV=development

# Postgres connection — matches infra/docker-compose.yml defaults.
DATABASE_URL=postgres://metallicore:metallicore_dev@localhost:5432/metallicore

# Local filesystem root for uploaded documents/drawings/attachments.
# Never a cloud bucket — this platform must run with zero internet access.
STORAGE_ROOT=./storage

LOG_LEVEL=info

# Signing secret for the server-side admin session cookie (see
# apps/web/src/auth/session.ts). Falls back to NEXT_PUBLIC_ADMIN_PASSWORD_HASH
# if unset — set a dedicated value in production.
ADMIN_SESSION_SECRET=change-me-in-production
